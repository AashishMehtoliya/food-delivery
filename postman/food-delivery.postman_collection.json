{
  "info": {
    "name": "Food Delivery API",
    "description": "End-to-end flow: register users -> admin sets up city/restaurant/delivery partner -> owner builds menu -> customer orders -> restaurant accepts -> partner accepts assignment & delivers -> customer rates. Includes cancel/reject branches and RBAC/error cases.\n\nRun via Collection Runner top-to-bottom in folder order — each request's test script captures IDs into collection variables for the next request, so nothing needs to be copy-pasted manually.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "adminEmail",
      "value": "admin@fooddelivery.com"
    },
    {
      "key": "adminPassword",
      "value": "admin123"
    },
    {
      "key": "ownerEmail",
      "value": "owner@x.com"
    },
    {
      "key": "ownerPassword",
      "value": "password"
    },
    {
      "key": "custEmail",
      "value": "cust@x.com"
    },
    {
      "key": "custPassword",
      "value": "password"
    },
    {
      "key": "cust2Email",
      "value": "cust2@x.com"
    },
    {
      "key": "cust2Password",
      "value": "password"
    },
    {
      "key": "partnerEmail",
      "value": "partner@x.com"
    },
    {
      "key": "partnerPassword",
      "value": "password"
    },
    {
      "key": "ownerId",
      "value": ""
    },
    {
      "key": "custId",
      "value": ""
    },
    {
      "key": "cust2Id",
      "value": ""
    },
    {
      "key": "partnerUserId",
      "value": ""
    },
    {
      "key": "cityId",
      "value": ""
    },
    {
      "key": "restaurantId",
      "value": ""
    },
    {
      "key": "partnerId",
      "value": ""
    },
    {
      "key": "menuItemId",
      "value": ""
    },
    {
      "key": "orderId",
      "value": ""
    },
    {
      "key": "orderIdCancel",
      "value": ""
    },
    {
      "key": "orderIdReject",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Register",
      "description": "ADMIN cannot self-register (AuthService.register rejects role=ADMIN with INVALID_ROLE_ASSIGNMENT) — the admin used throughout this collection is the Flyway-seeded bootstrap account (V2__seed_admin_user.sql: admin@fooddelivery.com / admin123), set via the adminEmail/adminPassword collection variables.",
      "item": [
        {
          "name": "Register restaurant owner",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Owner\",\"email\":\"{{ownerEmail}}\",\"password\":\"{{ownerPassword}}\",\"role\":\"RESTAURANT_OWNER\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('ownerId', pm.response.json().id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Cust\",\"email\":\"{{custEmail}}\",\"password\":\"{{custPassword}}\",\"role\":\"CUSTOMER\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('custId', pm.response.json().id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register second customer (for ownership test)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Cust2\",\"email\":\"{{cust2Email}}\",\"password\":\"{{cust2Password}}\",\"role\":\"CUSTOMER\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('cust2Id', pm.response.json().id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register delivery partner",
