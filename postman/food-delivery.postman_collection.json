                  "pm.test('status is PLACED', () => pm.expect(json.status).to.eql('PLACED'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get order (customer)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/{{orderId}}",
            "auth": {
              "type": "basic",
              "basic": [
