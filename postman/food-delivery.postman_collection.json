                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Partner\",\"email\":\"{{partnerEmail}}\",\"password\":\"{{partnerPassword}}\",\"role\":\"DELIVERY_PARTNER\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('partnerUserId', pm.response.json().id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
