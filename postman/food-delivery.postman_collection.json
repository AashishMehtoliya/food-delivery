    {
      "name": "7. Reject Branch",
      "item": [
        {
          "name": "Place order (to reject)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/orders",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{custEmail}}"
                },
                {
                  "key": "password",
                  "value": "{{custPassword}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"restaurantId\":{{restaurantId}},\"items\":[{\"menuItemId\":{{menuItemId}},\"quantity\":1}]}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('orderIdReject', pm.response.json().id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Restaurant rejects order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/orders/{{orderIdReject}}/reject",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{ownerEmail}}"
                },
                {
                  "key": "password",
                  "value": "{{ownerPassword}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('status is REJECTED', () => pm.expect(pm.response.json().status).to.eql('REJECTED'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "8. RBAC and Error Cases",
      "item": [
        {
          "name": "No auth -> 401",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/{{orderId}}",
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('401 Unauthenticated', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Self-register as ADMIN -> 400",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"ShouldFail\",\"email\":\"shouldfail@x.com\",\"password\":\"password\",\"role\":\"ADMIN\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('400 Bad Request', () => pm.response.to.have.status(400));",
                  "pm.test('error is INVALID_ROLE_ASSIGNMENT', () => pm.expect(pm.response.json().error).to.eql('INVALID_ROLE_ASSIGNMENT'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Wrong role (customer calling admin endpoint) -> 403",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/admin/cities",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{custEmail}}"
                },
                {
                  "key": "password",
                  "value": "{{custPassword}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"ShouldFail\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('403 Forbidden', () => pm.response.to.have.status(403));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Ownership violation (other customer views order) -> 403",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/{{orderId}}",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{cust2Email}}"
                },
                {
                  "key": "password",
                  "value": "{{cust2Password}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('403 Forbidden', () => pm.response.to.have.status(403));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Insufficient stock -> 4xx",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/orders",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{custEmail}}"
                },
                {
                  "key": "password",
                  "value": "{{custPassword}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"restaurantId\":{{restaurantId}},\"items\":[{\"menuItemId\":{{menuItemId}},\"quantity\":999999}]}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('4xx insufficient stock', () => pm.expect(pm.response.code).to.be.within(400, 499));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Invalid transition (order already DELIVERED) -> 4xx",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/orders/{{orderId}}/status",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{partnerEmail}}"
                },
                {
                  "key": "password",
                  "value": "{{partnerPassword}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"status\":\"OUT_FOR_DELIVERY\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('4xx invalid transition', () => pm.expect(pm.response.code).to.be.within(400, 499));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
