            "body": {
              "mode": "raw",
              "raw": "{\"restaurantId\":{{restaurantId}},\"items\":[{\"menuItemId\":{{menuItemId}},\"quantity\":2}]}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
